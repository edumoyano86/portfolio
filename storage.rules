rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Reglas para la carpeta de imágenes de los usuarios
    match /images/{userId}/{allPaths=**} {
      // Permite la lectura pública para que cualquiera pueda ver las imágenes.
      allow read;
      
      // Permite la escritura (subir, actualizar, eliminar) solo si el usuario
      // está autenticado y su UID coincide con el de la carpeta.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
